{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprut-agent-kit.local/contracts/export-manifest.schema.json",
  "title": "SanitizedExportManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "created_at",
    "source_host",
    "bundle_file",
    "bundle_sha256",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[a-z0-9_-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_host": {
      "type": "string",
      "minLength": 1
    },
    "bundle_file": {
      "type": "string",
      "pattern": "^sanitized-bundle-.*\\.tar\\.gz$"
    },
    "bundle_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "quarantine_count": {
      "type": "integer",
      "minimum": 0
    }
  }
}
