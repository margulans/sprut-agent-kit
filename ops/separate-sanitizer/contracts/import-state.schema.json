{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprut-agent-kit.local/contracts/import-state.schema.json",
  "title": "ImportConsumerState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consumer",
    "last_bundle_id",
    "last_bundle_sha256",
    "imported_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "consumer": {
      "type": "string",
      "enum": ["claudeclaw", "openclaw"]
    },
    "last_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "last_bundle_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "imported_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
