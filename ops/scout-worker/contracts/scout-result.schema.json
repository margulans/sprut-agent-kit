{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprut-agent-kit.local/contracts/scout-result.schema.json",
  "title": "ScoutResult",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "request_id",
    "task_type",
    "source_bot",
    "created_at",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 8
    },
    "task_type": {
      "type": "string",
      "enum": [
        "weather_lookup",
        "web_search",
        "youtube_search",
        "social_search",
        "messenger_channels_search",
        "deep_research",
        "reddit_scan",
        "youtube_transcribe",
        "summarize_text",
        "analyze_topic",
        "skills_catalog",
        "web_research"
      ]
    },
    "source_bot": {
      "type": "string",
      "const": "scout"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string"
        },
        "temperature_c": {
          "type": "number"
        },
        "wind_m_s": {
          "type": "number"
        },
        "humidity_pct": {
          "type": "number"
        },
        "query": {
          "type": "string"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "videos": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "posts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "top_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "error_message": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ttl_sec": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        }
      },
      "then": {
        "required": [
          "result"
        ],
        "properties": {
          "result": {
            "required": [
              "summary"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "error"
          }
        }
      },
      "then": {
        "required": [
          "error_message"
        ]
      }
    }
  ]
}
