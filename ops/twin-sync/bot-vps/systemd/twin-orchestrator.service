[Unit]
Description=Twin Orchestrator (ClaudeClaw/OpenClaw)
After=network.target

[Service]
Type=oneshot
User=__BOT_AGENT_USER__
Group=__BOT_AGENT_GROUP__
ExecStart=/usr/bin/python3 __REPO_DIR__/ops/twin-sync/bot-vps/twin_orchestrator.py --once --base-dir __BOT_HOME__/twin-sync
WorkingDirectory=__BOT_HOME__
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=__BOT_HOME__/twin-sync __REPO_DIR__

[Install]
WantedBy=multi-user.target
