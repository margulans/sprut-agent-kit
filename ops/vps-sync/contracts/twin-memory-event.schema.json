{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprut-agent-kit.local/contracts/twin-memory-event.schema.json",
  "title": "TwinMemoryEvent",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "event_id",
    "agent_id",
    "timestamp",
    "domain",
    "fact_type",
    "fact_payload",
    "confidence",
    "source_provenance",
    "trust_level"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$"
    },
    "agent_id": {
      "type": "string",
      "enum": ["claudeclaw", "openclaw"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "domain": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    },
    "fact_type": {
      "type": "string",
      "enum": [
        "observation",
        "best_practice",
        "rule",
        "preference",
        "warning",
        "interaction_pattern"
      ]
    },
    "fact_payload": {
      "type": "object",
      "minProperties": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_provenance": {
      "type": "string",
      "enum": [
        "owner_direct",
        "sanitized_external",
        "internal_inference"
      ]
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "trusted_owner",
        "verified_bundle",
        "untrusted",
        "internal"
      ]
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$"
      },
      "maxItems": 20
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "maxItems": 32
    }
  }
}
