{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprut-agent-kit.local/contracts/twin-config-proposal.schema.json",
  "title": "TwinConfigProposal",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "proposal_id",
    "created_at",
    "source_agent",
    "target_agent",
    "proposal_type",
    "title",
    "rationale",
    "risk_level",
    "auto_apply",
    "changes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_agent": {
      "type": "string",
      "enum": ["claudeclaw", "openclaw"]
    },
    "target_agent": {
      "type": "string",
      "enum": ["claudeclaw", "openclaw"]
    },
    "proposal_type": {
      "type": "string",
      "enum": ["config_alignment", "best_practice_adoption"]
    },
    "title": {
      "type": "string",
      "minLength": 4,
      "maxLength": 160
    },
    "rationale": {
      "type": "string",
      "minLength": 8
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "auto_apply": {
      "type": "boolean",
      "const": false
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "source_value", "target_value", "action"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "source_value": {},
          "target_value": {},
          "action": {
            "type": "string",
            "enum": ["set", "remove", "review"]
          },
          "reason": {
            "type": "string",
            "maxLength": 400
          }
        }
      }
    },
    "evidence_event_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$"
      },
      "maxItems": 100
    },
    "apply_hints": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 64
    }
  }
}
